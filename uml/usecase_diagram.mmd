            UC9["EasySave.exe 2<br/>(single execution)"]
        end

        subgraph System["System Operations"]
            UC10["Select language<br/>(EN / FR)"]
            UC11["Copy files +<br/>subdirectories"]
            UC12["Write daily log<br/>(date.json)"]
            UC13["Update real-time<br/>status (state.json)"]
            UC14["Save/Load config<br/>(config.json)"]
        end
    end

